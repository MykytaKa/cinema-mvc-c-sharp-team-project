@model Core.Models.BookSessionViewModel

<div class="container text-center">
    <h2 class="mb-3">@Model.FilmName</h2>
    <p><strong>Date:</strong> @Model.SessionDate.ToString("dd.MM.yyyy HH:mm")</p>
    <p><strong>Hall:</strong> @Model.HallName</p>

    <!-- Легенда цін -->
    <div class="d-flex justify-content-center align-items-center mb-3">
        <span class="seat-legend standard"></span> @Model.SessionPrice UAH
        <span class="seat-legend booked ms-3"></span> Reserved
    </div>

    <!-- Місця у залі -->
    <form method="post" asp-action="ConfirmBooking">
        <input type="hidden" asp-for="SessionId" />

        <div class="screen text-center mb-4">SCREEN</div>

        <div class="seat-container">
            @foreach (var row in Model.AvailableSeats.GroupBy(s => s.Row).OrderBy(r => r.Key)) // Додаємо OrderBy
            {
                <div class="seat-row">
                    <span class="row-number">@row.Key</span> <!-- Номер ряду -->
                    @foreach (var seat in row.OrderBy(s => s.Column)) // Додаємо сортування місць в рядку
                    {
                        var isBooked = seat.IsBooked ? "booked" : "";
                        var isDisabled = seat.IsBooked ? "disabled" : "";

                        <label class="seat @isBooked" data-row="@seat.Row" data-column="@seat.Column"
                               onmouseover="showSeatNumber(this)" onmouseout="hideSeatNumber()">
                            <input type="checkbox" name="SelectedSeats" value="@seat.SeatId" class="seat-checkbox"
                                   data-price="@Model.SessionPrice" onchange="updateTotalPrice()" @isDisabled />
                            <span></span>
                        </label>
                    }
                    <span class="row-number">@row.Key</span> <!-- Номер ряду -->
                </div>
            }
        </div>

        <!-- Відображення загальної вартості -->
        <div class="total-price mt-3">
            <strong>Total amount: <span id="total-price">0</span> UAH</strong>
        </div>

        <!-- Підсвічений номер місця -->
        <div id="seat-info" class="seat-info">Row: -, Seat: -</div>

        <button type="submit" class="btn btn-warning btn-lg mt-4">BUY TICKETS</button>
    </form>
</div>

<!-- Стилі для розміщення місць -->
<style>
    .screen {
        background-color: #ddd;
        color: black;
        font-size: 18px;
        font-weight: bold;
        padding: 10px;
        border-radius: 5px;
        width: 50%;
        margin: auto;
    }

    .seat-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }

    .seat-row {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 5px;
    }

    .row-number {
        width: 30px;
        font-weight: bold;
        text-align: center;
        color: #333;
    }

    .seat {
        position: relative;
        width: 25px;
        height: 25px;
        margin: 3px;
        border-radius: 5px;
        cursor: pointer;
    }

    .seat input {
        display: none;
    }

    .seat span {
        display: block;
        width: 100%;
        height: 100%;
        background-color: #87CEFA;
        border-radius: 5px;
    }

    .seat.booked span {
        background-color: #A9A9A9;
        cursor: not-allowed;
    }

    .seat input:checked + span {
        background-color: #FFA500;
    }

    .seat-legend {
        display: inline-block;
        width: 20px;
        height: 20px;
        margin-right: 5px;
        border-radius: 5px;
    }

    .seat-legend.standard {
        background-color: #87CEFA;
    }

    .seat-legend.booked {
        background-color: #A9A9A9;
    }

    .btn-warning {
        font-size: 18px;
        padding: 10px 30px;
        font-weight: bold;
    }

    /* Підсвічений номер місця */
    .seat-info {
        position: absolute;
        top: 30px;
        left: 50%;
        transform: translateX(-50%);
        background-color: rgba(0, 0, 0, 0.8);
        color: #fff;
        padding: 5px 10px;
        border-radius: 5px;
        display: none;
        font-size: 14px;
    }
</style>

<!-- Скрипти -->
<script>
    function showSeatNumber(seat) {
        var row = seat.getAttribute("data-row");
        var column = seat.getAttribute("data-column");
        var seatInfo = document.getElementById("seat-info");

        if (!seat.classList.contains("booked")) {
            seatInfo.innerText = `Row: ${row}, Seat: ${column}`;
            seatInfo.style.display = "block";
        }
    }

    function hideSeatNumber() {
        var seatInfo = document.getElementById("seat-info");
        seatInfo.style.display = "none";
    }

    function updateTotalPrice() {
        let totalPrice = 0;
        document.querySelectorAll(".seat-checkbox:checked").forEach(seat => {
            totalPrice += parseFloat(seat.getAttribute("data-price"));
        });
        document.getElementById("total-price").innerText = totalPrice;
    }
</script>



