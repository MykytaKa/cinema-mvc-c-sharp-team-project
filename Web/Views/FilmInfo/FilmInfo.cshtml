@model Core.Entities.Film<div class="filminfo">    <h1>Title: @Model.Name </h1>    <div class="poster">        <img src="@Model.PosterURL" align="left" width="450" />    </div>    <div class="details">        <p class="fs-4"><strong>Director:</strong> @Model.Director </p>        <p class="fs-4"><strong>Age Rating:</strong> @Model.AgeRating </p>        <p class="fs-4"><strong>Duration:</strong> @Model.Duration </p>        <p class="fs-4"><strong>Genres:</strong> @(Model?.Genres != null ? string.Join(", ", Model.Genres.Select(g => g.Name)) : "���� �����") </p>        <p class="fs-4"><strong>Actors:</strong> @(Model?.Actors != null ? string.Join(", ", Model.Actors.Select(a => $"{a.FirstName} {a.LastName}")) : "���� ������") </p>        <p class="fs-4"><strong>Release Date:</strong> @Model.ReleaseRate</p>        <p class="fs-4"><strong>Rating:</strong> @Model.Rating</p>        <p class="fs-4"><strong>Description:</strong> @Model.Description</p>    </div>    <div class=" trailer">        <h2>Trailer:</h2>        @if (!string.IsNullOrEmpty(Model.TrailerURL))        {            <div style="text-align: center;">                <iframe width="560" height="315"                         src="@GetEmbedUrl(Model.TrailerURL)"                        frameborder="0"                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"                        allowfullscreen>                </iframe>            </div>        }        else        {            <p>Не вказано відео для перегляду.</p>        }    </div></div>@section Scripts{    @functions {        public static string GetEmbedUrl(string youtubeUrl)        {            if (string.IsNullOrEmpty(youtubeUrl))                return string.Empty;            // Витягуємо VideoID            var uri = new Uri(youtubeUrl);            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);            var videoId = query["v"];            return videoId != null ? $"https://www.youtube.com/embed/{videoId}" : youtubeUrl;        }    }}