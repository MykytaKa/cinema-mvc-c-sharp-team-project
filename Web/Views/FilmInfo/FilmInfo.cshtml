@model Core.Entities.Film<div class="container mt-5">    <div class="card shadow-lg rounded">        <div class="row g-0">            <!-- Постер -->            <div class="col-md-4 text-center p-3">                <img src="@Model.PosterURL" class="img-fluid rounded" alt="Poster">            </div>            <!-- Інформація про фільм -->            <div class="col-md-8">                <div class="card-body">                    <h1 class="card-title text-primary">@Model.Name</h1>                    <p class="fs-5"><strong>Director:</strong> @Model.Director</p>                    <p class="fs-5"><strong>Age Rating:</strong> @Model.AgeRating</p>                    <p class="fs-5"><strong>Duration:</strong> @Model.Duration min</p>                    <p class="fs-5"><strong>Genres:</strong> @(Model?.Genres != null ? string.Join(", ", Model.Genres.Select(g => g.Name)) : "Жанри відсутні")</p>                    <p class="fs-5"><strong>Actors:</strong> @(Model?.Actors != null ? string.Join(", ", Model.Actors.Select(a => $"{a.FirstName} {a.LastName}")) : "Актори відсутні")</p>                    <p class="fs-5"><strong>Release Date:</strong> @Model.ReleaseRate.ToShortDateString()</p>                    <p class="fs-5"><strong>Rating:</strong> ⭐ @(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "Unrated")</p>                    <p class="fs-5"><strong>Description:</strong> @Model.Description</p>                </div>            </div>        </div>        <!-- Трейлер -->        <div class="card-footer bg-light text-center">            <h2 class="text-secondary">Trailer</h2>            @if (!string.IsNullOrEmpty(Model.TrailerURL))            {                <div class="ratio ratio-16x9">                    <iframe src="@GetEmbedUrl(Model.TrailerURL)" allowfullscreen></iframe>                </div>            }            else            {                <p class="text-muted">Не вказано відео для перегляду.</p>            }        </div>    </div></div>@section Scripts{    @functions {    public static string GetEmbedUrl(string youtubeUrl)    {        if (string.IsNullOrEmpty(youtubeUrl))            return string.Empty;        // Витягуємо VideoID        var uri = new Uri(youtubeUrl);        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);        var videoId = query["v"];        return videoId != null ? $"https://www.youtube.com/embed/{videoId}" : youtubeUrl;    }    }}