@model List<FilmRecoViewModel>

@{
    ViewData["Title"] = "Recommendations";
}

<div class="container mt-5">
@if(Model.Any())
{
    <h1 class="text-center mb-4">Recommended Films</h1>

    <div class="row justify-content-center">
        @foreach (var film in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-2 mb-4">
                <div class="card text-center">
                    <a asp-controller="FilmInfo" asp-action="FilmInfo" asp-route-id="@film.Id" class="card text-center film-card shadow-sm" style="text-decoration: none;">
                        <img src="@film.PosterUrl" class="card-img-top" alt="@film.Title" style="max-height: 300px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title" style="font-size: 1.1em; overflow-wrap: break-word;">@film.Title</h5>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}
else 
{
    <div class="no-films-container">
        <p>No films were found that you might like.</p>
    </div>
}
</div>


<style>
    .film-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
        border: 1px solid #ddd;
        background-color: white;
    }

    .film-card:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        background-color: #f7f7f7;
    }

    .no-films-container {
        text-align: center;
        margin-top: 50px;
        font-size: 20px;
        color: #555;
    }
</style>