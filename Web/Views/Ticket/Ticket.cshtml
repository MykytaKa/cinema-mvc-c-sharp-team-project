@model List<TicketViewModel>

<div class="mb-3 d-flex justify-content-center">
    <button class="btn btn-primary mx-2" onclick="location.href='@Url.Action("ShowUserTickets", new { status = "Reserved" })'">Reserved</button>
    <button class="btn btn-secondary mx-2" onclick="location.href='@Url.Action("ShowUserTickets", new { status = "Checked-in" })'">Checked-in</button>
    <button class="btn btn-success mx-2" onclick="location.href='@Url.Action("ShowUserTickets", new { status = "Cancelled" })'">Cancelled</button>
    <button class="btn btn-danger mx-2" onclick="location.href='@Url.Action("ShowUserTickets", new { status = "Refunded" })'">Refunded</button>
    <button class="btn btn-danger mx-2" onclick="location.href='@Url.Action("ShowUserTickets", new { status = "Expired" })'">Expired</button>
</div>

@foreach (var ticket in Model)
{
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card mb-3">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <img src="@ticket.FilmPosterURL" alt="@ticket.FilmTitle" class="img-fluid rounded-start" style="max-height: 210px; width: auto; display: block; margin: auto;" />
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h5 class="card-title">@ticket.FilmTitle</h5>
                                <p class="card-text"><strong>Hall:</strong> @ticket.HallName</p>
                                <p class="card-text"><strong>Seat:</strong> Row @ticket.Row, Seat @ticket.Column</p>
                                <p class="card-text"><strong>Showtime:</strong> @ticket.DateTimeBeg.ToString("dd.MM.yyyy HH:mm")</p>
                                <p class="card-text"><strong>Price:</strong> @ticket.Price UAH</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
