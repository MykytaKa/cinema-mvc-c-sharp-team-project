@model IEnumerable<Core.Entities.Film>

<div class="container">
    <div class="text-center">
        <div class="container mt-2 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="text-center flex-grow-1">Session</h1>
                <button type="button" class="btn btn-success">Create Session</button>
            </div>
        </div>
        <div id="moviesContainer" class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var movie in Model)
                {
                    <div class="col">
                        <div class="card h-100">
                            <img class="card-img-top" src="@movie.PosterURL" alt="@movie.Name">
                            <div class="card-body">
                                <h5 class="card-title">@movie.Name</h5>
                                <p class="card-text">
                                    Жанр: @string.Join(", ", movie.Genres.Select(g => g.Name))<br/>
                                    Рейтинг: @movie.Rating<br/>
                                    Тривалість: @movie.Duration хв<br/>
                                    Віковий рейтинг: @movie.AgeRating<br/>
                                    Дата виходу: @movie.ReleaseRate.ToString("dd.MM.yyyy")<br/>
                                    Сеанс: 
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

